# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vinevault_core_db

# JWT
SECRET_KEY=change_me_to_a_secure_random_secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Service
SERVICE_NAME=vinevault-core
ENVIRONMENT=development

# Kafka (optional)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP_ID=vinevault-core

# Billing Service (optional)
BILLING_SERVICE_URL=http://localhost:8001
